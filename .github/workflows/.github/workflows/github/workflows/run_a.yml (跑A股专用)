name: A-Share Screener

on:
  schedule:
    # 每天 UTC 时间 08:00 运行 (北京时间下午 4:00, A股收盘后跑)
    - cron: '0 8 * * 1-5'
  workflow_dispatch: 

jobs:
  run-a-screener:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v3

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.10'

      - name: Install dependencies
        run: pip install -r requirements.txt

      - name: Create credentials.json
        run: |
          echo '${{ secrets.GCP_CREDENTIALS }}' > credentials.json

      - name: Run A-Share Screener
        run: python run_a.py
